# Firebase Config
# This is required for Firestore backend integration on platforms like Vercel.
# Paste the entire JSON content from your Firebase Service Account private key file here.
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# JWT Secret (Essential for Auth)
JWT_SECRET="generate_a_strong_random_string_here"

# Gemini API Key (For AI functions)
GEMINI_API_KEY="your_actual_gemini_api_key"

# Server Config
PORT=3000
NODE_ENV=production

# Database Notes:
# This project currently uses a local db.json file.
# On cloud platforms like Vercel or Netlify, file system writes are ephemeral.
# For a real production app, it is HIGHLY RECOMMENDED to use a real database
# like Firestore, MongoDB, or PostgreSQL.
